{
  "name": "@app/web",
  "version": "0.0.0",
  "exports": "./src/main.tsx",
  "imports": {
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^5.1.4",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.1",
    "vite": "npm:vite@^7.3.1",
    "react": "npm:react@^19.2.4",
    "react/": "npm:/react@^19.2.4/",
    "@types/react": "npm:@types/react@^19.2.14",
    "react-dom": "npm:react-dom@^19.2.4",
    "react-dom/": "npm:/react-dom@^19.2.4/",
    "react-error-boundary": "npm:react-error-boundary@^6.1.1",
    "react-router-dom": "npm:react-router-dom@^7.13.1",
    "@tanstack/react-query": "npm:@tanstack/react-query@^5.90.21",
    "@tanstack/react-query-devtools": "npm:@tanstack/react-query-devtools@^5.91.3",
    "react-hook-form": "npm:react-hook-form@^7.71.2",
    "@hookform/resolvers": "npm:@hookform/resolvers@^5.2.2",
    "zustand": "npm:zustand@^5.0.11",
    "hono": "npm:hono@^4.12.5",
    "rollup": "npm:rollup@^4.59.0",
    "clsx": "npm:clsx@^2.1.1",
    "dayjs": "npm:dayjs@^1.11.19",
    "tailwindcss": "npm:tailwindcss@^4.2.1",
    "msw": "npm:msw@^2.12.10",
    "@testing-library/react": "npm:@testing-library/react@^16.3.2",
    "jsdom": "npm:jsdom@^28.1.0",
    "@/": "./src/"
  },
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "test": "deno test --allow-net --allow-env --allow-read --allow-write src/",
    "check": "deno check src/**/*.ts src/**/*.tsx"
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
